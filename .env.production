# ============ API基础地址 ============

# 通用API基础地址 -> 使用相对路径，由 Nginx 反向代理处理
VITE_API_BASE_URL=/api

# 聊天API基础地址 -> 使用相对路径，由 Nginx 反向代理处理
VITE_CHAT_API_BASE=/chatApi
VITE_KNOWLEDGE_API_BASE=/knowledgeApi

# 功能API基础地址 (Dify) - 直接使用完整URL
VITE_DIFY_API_BASE=difyApi

# 180本地接口
VITE_API_URL=/localApi

#服务器224接口
VITE_PARSE_API_URL=/serverApi
